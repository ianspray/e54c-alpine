pkgname=e52c-usb-updater-services
pkgver=0.1.0
pkgrel=0
pkgdesc="E52C updater OpenRC service and eMMC update runner"
url="https://example.invalid/e52c-alpian"
arch="noarch"
license="MIT"
depends="openrc zstd"
source="
  e52c-run-usb-update.sh
  e52c-usb-emmc-update.initd
  e52c-usb-emmc-update.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/e52c-run-usb-update.sh "$pkgdir"/usr/sbin/e52c-run-usb-update
  install -Dm755 "$srcdir"/e52c-usb-emmc-update.initd "$pkgdir"/etc/init.d/e52c-usb-emmc-update
  install -Dm644 "$srcdir"/e52c-usb-emmc-update.confd "$pkgdir"/etc/conf.d/e52c-usb-emmc-update
}

