# SPDX-License-Identifier: MIT
# Maintainer: IWS <iws@toothless.local>
pkgname=e52c-openrc-services
pkgver=0.3.0
pkgrel=0
pkgdesc="E52C OpenRC helper services for diskless and serial operation"
url="https://example.invalid/e52c-alpian"
arch="noarch"
license="MIT"
depends="openrc busybox iproute2"
replaces="busybox"
source="
  e52c-apply-dev-perms.sh
  e52c-dev-perms.initd
  e52c-dev-perms.confd
  show-net-addrs.sh
  show-net-addrs.initd
  show-net-addrs.confd
  e52c-ntp-sync.initd
  e52c-ntp-sync.confd
  e52c-boot-mode.sh
  e52c-bootmode-oneshot-apply.sh
  e52c-bootmode-oneshot.initd
  e52c-root-mode.initd
  e52c-udhcpc.sh
  e52c-net-mac-sort.sh
  e52c-net-mac-sort.initd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/e52c-apply-dev-perms.sh "$pkgdir"/usr/sbin/e52c-apply-dev-perms
  install -Dm755 "$srcdir"/show-net-addrs.sh "$pkgdir"/usr/sbin/show-net-addrs
  install -Dm755 "$srcdir"/e52c-boot-mode.sh "$pkgdir"/usr/sbin/e52c-boot-mode
  install -Dm755 "$srcdir"/e52c-bootmode-oneshot-apply.sh "$pkgdir"/usr/sbin/e52c-bootmode-oneshot-apply

  install -Dm755 "$srcdir"/e52c-dev-perms.initd "$pkgdir"/etc/init.d/e52c-dev-perms
  install -Dm644 "$srcdir"/e52c-dev-perms.confd "$pkgdir"/etc/conf.d/e52c-dev-perms

  install -Dm755 "$srcdir"/show-net-addrs.initd "$pkgdir"/etc/init.d/show-net-addrs
  install -Dm644 "$srcdir"/show-net-addrs.confd "$pkgdir"/etc/conf.d/show-net-addrs

  install -Dm755 "$srcdir"/e52c-ntp-sync.initd "$pkgdir"/etc/init.d/e52c-ntp-sync
  install -Dm644 "$srcdir"/e52c-ntp-sync.confd "$pkgdir"/etc/conf.d/e52c-ntp-sync

  install -Dm755 "$srcdir"/e52c-bootmode-oneshot.initd "$pkgdir"/etc/init.d/e52c-bootmode-oneshot
  install -Dm755 "$srcdir"/e52c-root-mode.initd "$pkgdir"/etc/init.d/e52c-root-mode

  install -Dm755 "$srcdir"/e52c-udhcpc.sh "$pkgdir"/usr/share/udhcpc/default.script
  install -Dm755 "$srcdir"/e52c-net-mac-sort.sh "$pkgdir"/usr/sbin/e52c-net-mac-sort
  install -Dm755 "$srcdir"/e52c-net-mac-sort.initd "$pkgdir"/etc/init.d/e52c-net-mac-sort
}

