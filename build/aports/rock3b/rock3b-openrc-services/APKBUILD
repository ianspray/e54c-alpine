# SPDX-License-Identifier: MIT
# Maintainer: IWS <iws@toothless.local>
pkgname=rock3b-openrc-services
pkgver=0.1.0
pkgrel=0
pkgdesc="ROCK3B OpenRC helper services for diskless and serial operation"
url="https://example.invalid/rock3b-alpian"
arch="noarch"
license="MIT"
depends="openrc busybox"
source="
  rock3b-apply-dev-perms.sh
  rock3b-dev-perms.initd
  rock3b-dev-perms.confd
  show-net-addrs.sh
  show-net-addrs.initd
  show-net-addrs.confd
  rock3b-ntp-sync.initd
  rock3b-ntp-sync.confd
  rock3b-boot-mode.sh
  rock3b-bootmode-oneshot-apply.sh
  rock3b-bootmode-oneshot.initd
  rock3b-root-mode.initd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/rock3b-apply-dev-perms.sh "$pkgdir"/usr/sbin/rock3b-apply-dev-perms
  install -Dm755 "$srcdir"/show-net-addrs.sh "$pkgdir"/usr/sbin/show-net-addrs
  install -Dm755 "$srcdir"/rock3b-boot-mode.sh "$pkgdir"/usr/sbin/rock3b-boot-mode
  install -Dm755 "$srcdir"/rock3b-bootmode-oneshot-apply.sh "$pkgdir"/usr/sbin/rock3b-bootmode-oneshot-apply

  install -Dm755 "$srcdir"/rock3b-dev-perms.initd "$pkgdir"/etc/init.d/rock3b-dev-perms
  install -Dm644 "$srcdir"/rock3b-dev-perms.confd "$pkgdir"/etc/conf.d/rock3b-dev-perms

  install -Dm755 "$srcdir"/show-net-addrs.initd "$pkgdir"/etc/init.d/show-net-addrs
  install -Dm644 "$srcdir"/show-net-addrs.confd "$pkgdir"/etc/conf.d/show-net-addrs

  install -Dm755 "$srcdir"/rock3b-ntp-sync.initd "$pkgdir"/etc/init.d/rock3b-ntp-sync
  install -Dm644 "$srcdir"/rock3b-ntp-sync.confd "$pkgdir"/etc/conf.d/rock3b-ntp-sync

  install -Dm755 "$srcdir"/rock3b-bootmode-oneshot.initd "$pkgdir"/etc/init.d/rock3b-bootmode-oneshot
  install -Dm755 "$srcdir"/rock3b-root-mode.initd "$pkgdir"/etc/init.d/rock3b-root-mode
}

