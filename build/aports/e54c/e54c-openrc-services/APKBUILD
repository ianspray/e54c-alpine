# SPDX-License-Identifier: MIT
# Maintainer: IWS <iws@toothless.local>
pkgname=e54c-openrc-services
pkgver=0.1.0
pkgrel=0
pkgdesc="E54C OpenRC helper services for diskless and serial operation"
url="https://example.invalid/e54c-alpian"
arch="noarch"
license="MIT"
depends="openrc busybox"
source="
  e54c-apply-dev-perms.sh
  e54c-dev-perms.initd
  e54c-dev-perms.confd
  show-net-addrs.sh
  show-net-addrs.initd
  show-net-addrs.confd
  e54c-ntp-sync.initd
  e54c-ntp-sync.confd
  e54c-boot-mode.sh
  e54c-bootmode-oneshot-apply.sh
  e54c-bootmode-oneshot.initd
  e54c-root-mode.initd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/e54c-apply-dev-perms.sh "$pkgdir"/usr/sbin/e54c-apply-dev-perms
  install -Dm755 "$srcdir"/show-net-addrs.sh "$pkgdir"/usr/sbin/show-net-addrs
  install -Dm755 "$srcdir"/e54c-boot-mode.sh "$pkgdir"/usr/sbin/e54c-boot-mode
  install -Dm755 "$srcdir"/e54c-bootmode-oneshot-apply.sh "$pkgdir"/usr/sbin/e54c-bootmode-oneshot-apply

  install -Dm755 "$srcdir"/e54c-dev-perms.initd "$pkgdir"/etc/init.d/e54c-dev-perms
  install -Dm644 "$srcdir"/e54c-dev-perms.confd "$pkgdir"/etc/conf.d/e54c-dev-perms

  install -Dm755 "$srcdir"/show-net-addrs.initd "$pkgdir"/etc/init.d/show-net-addrs
  install -Dm644 "$srcdir"/show-net-addrs.confd "$pkgdir"/etc/conf.d/show-net-addrs

  install -Dm755 "$srcdir"/e54c-ntp-sync.initd "$pkgdir"/etc/init.d/e54c-ntp-sync
  install -Dm644 "$srcdir"/e54c-ntp-sync.confd "$pkgdir"/etc/conf.d/e54c-ntp-sync

  install -Dm755 "$srcdir"/e54c-bootmode-oneshot.initd "$pkgdir"/etc/init.d/e54c-bootmode-oneshot
  install -Dm755 "$srcdir"/e54c-root-mode.initd "$pkgdir"/etc/init.d/e54c-root-mode
}

