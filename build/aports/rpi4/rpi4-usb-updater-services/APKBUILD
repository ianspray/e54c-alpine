pkgname=rpi4-usb-updater-services
pkgver=0.1.0
pkgrel=0
pkgdesc="RPI4 USB updater OpenRC service and update runner"
url="https://example.invalid/rpi4-alpian"
arch="noarch"
license="MIT"
depends="openrc zstd"
source="
  rpi4-run-usb-update.sh
  rpi4-usb-nvme-update.initd
  rpi4-usb-nvme-update.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/rpi4-run-usb-update.sh "$pkgdir"/usr/sbin/rpi4-run-usb-update
  install -Dm755 "$srcdir"/rpi4-usb-nvme-update.initd "$pkgdir"/etc/init.d/rpi4-usb-nvme-update
  install -Dm644 "$srcdir"/rpi4-usb-nvme-update.confd "$pkgdir"/etc/conf.d/rpi4-usb-nvme-update
}

