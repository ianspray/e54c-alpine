# SPDX-License-Identifier: MIT
# Maintainer: IWS <iws@toothless.local>
pkgname=e25-openrc-services
pkgver=0.2.0
pkgrel=0
pkgdesc="E25 OpenRC helper services for diskless and serial operation"
url="https://example.invalid/e25-alpian"
arch="noarch"
license="MIT"
depends="openrc busybox iproute2"
source="
  e25-apply-dev-perms.sh
  e25-dev-perms.initd
  e25-dev-perms.confd
  show-net-addrs.sh
  show-net-addrs.initd
  show-net-addrs.confd
  e25-ntp-sync.initd
  e25-ntp-sync.confd
  e25-boot-mode.sh
  e25-bootmode-oneshot-apply.sh
  e25-bootmode-oneshot.initd
  e25-root-mode.initd
  e25-udhcpc.sh
  e25-net-mac-sort.sh
  e25-net-mac-sort.initd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/e25-apply-dev-perms.sh "$pkgdir"/usr/sbin/e25-apply-dev-perms
  install -Dm755 "$srcdir"/show-net-addrs.sh "$pkgdir"/usr/sbin/show-net-addrs
  install -Dm755 "$srcdir"/e25-boot-mode.sh "$pkgdir"/usr/sbin/e25-boot-mode
  install -Dm755 "$srcdir"/e25-bootmode-oneshot-apply.sh "$pkgdir"/usr/sbin/e25-bootmode-oneshot-apply

  install -Dm755 "$srcdir"/e25-dev-perms.initd "$pkgdir"/etc/init.d/e25-dev-perms
  install -Dm644 "$srcdir"/e25-dev-perms.confd "$pkgdir"/etc/conf.d/e25-dev-perms

  install -Dm755 "$srcdir"/show-net-addrs.initd "$pkgdir"/etc/init.d/show-net-addrs
  install -Dm644 "$srcdir"/show-net-addrs.confd "$pkgdir"/etc/conf.d/show-net-addrs

  install -Dm755 "$srcdir"/e25-ntp-sync.initd "$pkgdir"/etc/init.d/e25-ntp-sync
  install -Dm644 "$srcdir"/e25-ntp-sync.confd "$pkgdir"/etc/conf.d/e25-ntp-sync

  install -Dm755 "$srcdir"/e25-bootmode-oneshot.initd "$pkgdir"/etc/init.d/e25-bootmode-oneshot
  install -Dm755 "$srcdir"/e25-root-mode.initd "$pkgdir"/etc/init.d/e25-root-mode

  install -Dm755 "$srcdir"/e25-udhcpc.sh "$pkgdir"/usr/share/udhcpc/default.script
  install -Dm755 "$srcdir"/e25-net-mac-sort.sh "$pkgdir"/usr/sbin/e25-net-mac-sort
  install -Dm755 "$srcdir"/e25-net-mac-sort.initd "$pkgdir"/etc/init.d/e25-net-mac-sort
}

