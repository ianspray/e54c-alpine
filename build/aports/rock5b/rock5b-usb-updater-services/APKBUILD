pkgname=rock5b-usb-updater-services
pkgver=0.1.0
pkgrel=0
pkgdesc="ROCK5B USB updater OpenRC service and update runner"
url="https://example.invalid/rock5b-alpian"
arch="noarch"
license="MIT"
depends="openrc zstd"
source="
  rock5b-run-usb-update.sh
  rock5b-usb-nvme-update.initd
  rock5b-usb-nvme-update.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/rock5b-run-usb-update.sh "$pkgdir"/usr/sbin/rock5b-run-usb-update
  install -Dm755 "$srcdir"/rock5b-usb-nvme-update.initd "$pkgdir"/etc/init.d/rock5b-usb-nvme-update
  install -Dm644 "$srcdir"/rock5b-usb-nvme-update.confd "$pkgdir"/etc/conf.d/rock5b-usb-nvme-update
}

