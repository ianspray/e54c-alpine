# SPDX-License-Identifier: MIT
# Maintainer: IWS <iws@toothless.local>
pkgname=rock5b-openrc-services
pkgver=0.1.0
pkgrel=0
pkgdesc="ROCK5B OpenRC helper services for diskless and serial operation"
url="https://example.invalid/rock5b-alpian"
arch="noarch"
license="MIT"
depends="openrc busybox"
source="
  rock5b-apply-dev-perms.sh
  rock5b-dev-perms.initd
  rock5b-dev-perms.confd
  show-net-addrs.sh
  show-net-addrs.initd
  show-net-addrs.confd
  rock5b-ntp-sync.initd
  rock5b-ntp-sync.confd
  rock5b-boot-mode.sh
  rock5b-bootmode-oneshot-apply.sh
  rock5b-bootmode-oneshot.initd
  rock5b-root-mode.initd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/rock5b-apply-dev-perms.sh "$pkgdir"/usr/sbin/rock5b-apply-dev-perms
  install -Dm755 "$srcdir"/show-net-addrs.sh "$pkgdir"/usr/sbin/show-net-addrs
  install -Dm755 "$srcdir"/rock5b-boot-mode.sh "$pkgdir"/usr/sbin/rock5b-boot-mode
  install -Dm755 "$srcdir"/rock5b-bootmode-oneshot-apply.sh "$pkgdir"/usr/sbin/rock5b-bootmode-oneshot-apply

  install -Dm755 "$srcdir"/rock5b-dev-perms.initd "$pkgdir"/etc/init.d/rock5b-dev-perms
  install -Dm644 "$srcdir"/rock5b-dev-perms.confd "$pkgdir"/etc/conf.d/rock5b-dev-perms

  install -Dm755 "$srcdir"/show-net-addrs.initd "$pkgdir"/etc/init.d/show-net-addrs
  install -Dm644 "$srcdir"/show-net-addrs.confd "$pkgdir"/etc/conf.d/show-net-addrs

  install -Dm755 "$srcdir"/rock5b-ntp-sync.initd "$pkgdir"/etc/init.d/rock5b-ntp-sync
  install -Dm644 "$srcdir"/rock5b-ntp-sync.confd "$pkgdir"/etc/conf.d/rock5b-ntp-sync

  install -Dm755 "$srcdir"/rock5b-bootmode-oneshot.initd "$pkgdir"/etc/init.d/rock5b-bootmode-oneshot
  install -Dm755 "$srcdir"/rock5b-root-mode.initd "$pkgdir"/etc/init.d/rock5b-root-mode
}

