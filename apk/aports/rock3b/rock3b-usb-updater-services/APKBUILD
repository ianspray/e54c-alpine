pkgname=rock3b-usb-updater-services
pkgver=0.1.0
pkgrel=0
pkgdesc="ROCK3B USB updater OpenRC service and update runner"
url="https://example.invalid/rock3b-alpian"
arch="noarch"
license="MIT"
depends="openrc zstd"
source="
  rock3b-run-usb-update.sh
  rock3b-usb-nvme-update.initd
  rock3b-usb-nvme-update.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/rock3b-run-usb-update.sh "$pkgdir"/usr/sbin/rock3b-run-usb-update
  install -Dm755 "$srcdir"/rock3b-usb-nvme-update.initd "$pkgdir"/etc/init.d/rock3b-usb-nvme-update
  install -Dm644 "$srcdir"/rock3b-usb-nvme-update.confd "$pkgdir"/etc/conf.d/rock3b-usb-nvme-update
}

