#!/sbin/openrc-run
# SPDX-License-Identifier: MIT

name="rock3b-dev-perms"
description="Apply custom device-node permissions for fixed peripherals"

depend() {
  need modules
  before networking
}

start() {
  ebegin "Applying custom device permissions"
  /usr/sbin/rock3b-apply-dev-perms
  eend 0
}
