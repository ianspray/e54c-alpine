pkgname=alpian-apkovl-service
pkgver=0.1.0
pkgrel=0
pkgdesc="Alpian apkovl restore service for persistent configuration"
url="https://example.invalid/alpian"
arch="noarch"
license="MIT"
depends="openrc"
source="
	apkovl-restore.initd
	apkovl-restore.sh
"
builddir="$srcdir"
options="!check"

package() {
	install -Dm755 "$srcdir"/apkovl-restore.sh "$pkgdir"/usr/sbin/apkovl-restore
	install -Dm755 "$srcdir"/apkovl-restore.initd "$pkgdir"/etc/init.d/apkovl-restore
	install -Dm644 /dev/null "$pkgdir"/etc/conf.d/apkovl-restore
}

