#!/bin/sh
# SPDX-License-Identifier: MIT
# hostname-set - Change system hostname with lbu persistence and avahi restart
# Usage: hostname-set <new-hostname>
#
# This script:
# 1. Updates /etc/hostname with the new hostname
# 2. Uses lbu package to save the change to a fixed apkovl file
# 3. Restarts hostname service and avahi-daemon to apply changes immediately
#
# The apkovl file is /media/config/alpian.apkovl.tar.gz (fixed filename)
# and is loaded at boot via kernel cmdline: apkovl=PARTLABEL=config:/alpian.apkovl.tar.gz

set -e

usage() {
	echo "Usage: hostname-set <new-hostname>" >&2
	echo "       hostname-set -l" >&2
	echo "" >&2
	echo "Options:" >&2
	echo "  <new-hostname>   Set the system hostname" >&2
	echo "  -l, --show       Show current hostname" >&2
	exit 1
}

show_hostname() {
	if [ -f /etc/hostname ]; then
		cat /etc/hostname
	else
		hostname
	fi
}

validate_hostname() {
	local name="$1"
	if [ -z "$name" ]; then
		return 1
	fi
	if [ "${#name}" -gt 63 ]; then
		echo "Error: Hostname must be 63 characters or less" >&2
		return 1
	fi
	if ! echo "$name" | grep -EqE '^[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?$'; then
		echo "Error: Hostname must contain only letters, numbers, and hyphens" >&2
		echo "       Must start and end with a letter or number" >&2
		return 1
	fi
	return 0
}

case "${1:-}" in
	-l|--show|--list)
		show_hostname
		exit 0
		;;
	-h|--help)
		usage
		;;
	"")
		usage
		;;
esac

NEW_HOSTNAME="$1"

if ! validate_hostname "$NEW_HOSTNAME"; then
	exit 1
fi

CURRENT_HOSTNAME="$(show_hostname)"

if [ "$NEW_HOSTNAME" = "$CURRENT_HOSTNAME" ]; then
	echo "Hostname is already set to '$NEW_HOSTNAME'"
	exit 0
fi

echo "Setting hostname to '$NEW_HOSTNAME'..."

echo "$NEW_HOSTNAME" >/etc/hostname
hostname "$NEW_HOSTNAME"

echo "Persisting change with lbu package..."
if command -v lbu >/dev/null 2>&1; then
	ALPIAN_APKOVL="${ALPIAN_APKOVL:-/media/config/alpian.apkovl.tar.gz}"
	APKOVL_DIR="$(dirname "$ALPIAN_APKOVL")"

	mount -o remount,rw "$APKOVL_DIR" 2>/dev/null || mount -o remount,rw /media/config 2>/dev/null || mount -o remount,rw /dev/disk/by-label/config 2>/dev/null || {
		echo "Warning: Could not remount config partition as writable" >&2
		echo "Warning: changes may not persist after reboot" >&2
	}

	if lbu package "$ALPIAN_APKOVL"; then
		echo "Apkovl saved to $ALPIAN_APKOVL"
	else
		echo "Warning: lbu package failed, changes may not persist after reboot" >&2
	fi

	mount -o remount,ro /media/config 2>/dev/null || mount -o remount,ro /dev/disk/by-label/config 2>/dev/null || true
else
	echo "Warning: lbu not found, changes will not persist after reboot" >&2
fi

echo "Restarting services..."
if command -v rc-service >/dev/null 2>&1; then
	rc-service hostname restart 2>/dev/null || true
	rc-service avahi-daemon restart 2>/dev/null || true
fi

echo "Hostname set to '$NEW_HOSTNAME'"
echo ""
echo "You can now access this device as '${NEW_HOSTNAME}.local' on the local network via mDNS."
