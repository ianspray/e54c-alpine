pkgname=rpi4-partition-mount-service
pkgver=0.1.0
pkgrel=2
pkgdesc="RPI4 OpenRC NVMe Partition mounter"
url="https://example.invalid/rpi4-alpine"
arch="noarch"
license="MIT"
depends="openrc busybox"
source="
  rpi4-partition-mount.sh
  rpi4-partition-mount.initd
  rpi4-partition-mount.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/rpi4-partition-mount.sh "$pkgdir"/usr/sbin/rpi4-partition-mount

  install -Dm755 "$srcdir"/rpi4-partition-mount.initd "$pkgdir"/etc/init.d/rpi4-partition-mount
  install -Dm644 "$srcdir"/rpi4-partition-mount.confd "$pkgdir"/etc/conf.d/rpi4-partition-mount
}

