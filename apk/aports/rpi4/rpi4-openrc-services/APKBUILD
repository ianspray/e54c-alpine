# SPDX-License-Identifier: MIT
# Maintainer: IWS <iws@toothless.local>
pkgname=rpi4-openrc-services
pkgver=0.1.0
pkgrel=0
pkgdesc="RPI4 OpenRC helper services for diskless and serial operation"
url="https://example.invalid/rpi4-alpine"
arch="noarch"
license="MIT"
depends="openrc busybox"
source="
  rpi4-apply-dev-perms.sh
  rpi4-dev-perms.initd
  rpi4-dev-perms.confd
  show-net-addrs.sh
  show-net-addrs.initd
  show-net-addrs.confd
  rpi4-ntp-sync.initd
  rpi4-ntp-sync.confd
  rpi4-boot-mode.sh
  rpi4-bootmode-oneshot-apply.sh
  rpi4-bootmode-oneshot.initd
  rpi4-root-mode.initd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/rpi4-apply-dev-perms.sh "$pkgdir"/usr/sbin/rpi4-apply-dev-perms
  install -Dm755 "$srcdir"/show-net-addrs.sh "$pkgdir"/usr/sbin/show-net-addrs
  install -Dm755 "$srcdir"/rpi4-boot-mode.sh "$pkgdir"/usr/sbin/rpi4-boot-mode
  install -Dm755 "$srcdir"/rpi4-bootmode-oneshot-apply.sh "$pkgdir"/usr/sbin/rpi4-bootmode-oneshot-apply

  install -Dm755 "$srcdir"/rpi4-dev-perms.initd "$pkgdir"/etc/init.d/rpi4-dev-perms
  install -Dm644 "$srcdir"/rpi4-dev-perms.confd "$pkgdir"/etc/conf.d/rpi4-dev-perms

  install -Dm755 "$srcdir"/show-net-addrs.initd "$pkgdir"/etc/init.d/show-net-addrs
  install -Dm644 "$srcdir"/show-net-addrs.confd "$pkgdir"/etc/conf.d/show-net-addrs

  install -Dm755 "$srcdir"/rpi4-ntp-sync.initd "$pkgdir"/etc/init.d/rpi4-ntp-sync
  install -Dm644 "$srcdir"/rpi4-ntp-sync.confd "$pkgdir"/etc/conf.d/rpi4-ntp-sync

  install -Dm755 "$srcdir"/rpi4-bootmode-oneshot.initd "$pkgdir"/etc/init.d/rpi4-bootmode-oneshot
  install -Dm755 "$srcdir"/rpi4-root-mode.initd "$pkgdir"/etc/init.d/rpi4-root-mode
}

