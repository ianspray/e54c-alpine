pkgname=r3s-usb-updater-services
pkgver=0.1.0
pkgrel=0
pkgdesc="R3S updater OpenRC service and eMMC update runner"
url="https://example.invalid/r3s-alpian"
arch="noarch"
license="MIT"
depends="openrc zstd"
source="
  r3s-run-usb-update.sh
  r3s-usb-emmc-update.initd
  r3s-usb-emmc-update.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/r3s-run-usb-update.sh "$pkgdir"/usr/sbin/r3s-run-usb-update
  install -Dm755 "$srcdir"/r3s-usb-emmc-update.initd "$pkgdir"/etc/init.d/r3s-usb-emmc-update
  install -Dm644 "$srcdir"/r3s-usb-emmc-update.confd "$pkgdir"/etc/conf.d/r3s-usb-emmc-update
}

