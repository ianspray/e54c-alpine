pkgname=e25-usb-updater-services
pkgver=0.1.0
pkgrel=0
pkgdesc="E25 updater OpenRC service and eMMC update runner"
url="https://example.invalid/e25-alpian"
arch="noarch"
license="MIT"
depends="openrc zstd"
source="
  e25-run-usb-update.sh
  e25-usb-emmc-update.initd
  e25-usb-emmc-update.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/e25-run-usb-update.sh "$pkgdir"/usr/sbin/e25-run-usb-update
  install -Dm755 "$srcdir"/e25-usb-emmc-update.initd "$pkgdir"/etc/init.d/e25-usb-emmc-update
  install -Dm644 "$srcdir"/e25-usb-emmc-update.confd "$pkgdir"/etc/conf.d/e25-usb-emmc-update
}

sha512sums=""
