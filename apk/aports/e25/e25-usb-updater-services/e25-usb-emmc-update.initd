#!/sbin/openrc-run
# SPDX-License-Identifier: MIT

name="e25-usb-emmc-update"
description="Flash bundled eMMC image from updater media, then reboot"

depend() {
  need localmount
  before networking
}

start() {
  ebegin "Running USB to eMMC update flow"
  TARGET_DEVICE="${target_device:-/dev/mmcblk0}" \
    ROOT_PARTLABEL_REQUIRED="${root_partlabel:-e25-updater-rootfs}" \
    TARGET_WAIT_SECONDS="${target_wait_seconds:-120}" \
    /usr/sbin/e25-run-usb-update
  eend $?
}
