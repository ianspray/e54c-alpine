pkgname=e54c-openrc-sample
pkgver=0.1.0
pkgrel=0
pkgdesc="Sample OpenRC service package for E54C image customization"
url="https://example.invalid/alpian"
arch="noarch"
license="MIT"
depends="openrc"
source="
  e54c-sample-hook.initd
  e54c-sample-hook.confd
  e54c-sample-hook.sh
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/e54c-sample-hook.initd "$pkgdir"/etc/init.d/e54c-sample-hook
  install -Dm644 "$srcdir"/e54c-sample-hook.confd "$pkgdir"/etc/conf.d/e54c-sample-hook
  install -Dm755 "$srcdir"/e54c-sample-hook.sh "$pkgdir"/usr/libexec/e54c-sample-hook
}

