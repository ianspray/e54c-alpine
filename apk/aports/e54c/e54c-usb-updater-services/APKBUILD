pkgname=e54c-usb-updater-services
pkgver=0.1.0
pkgrel=0
pkgdesc="E54C USB updater OpenRC service and update runner"
url="https://example.invalid/e54c-alpian"
arch="noarch"
license="MIT"
depends="openrc zstd"
source="
  e54c-run-usb-update.sh
  e54c-usb-nvme-update.initd
  e54c-usb-nvme-update.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/e54c-run-usb-update.sh "$pkgdir"/usr/sbin/e54c-run-usb-update
  install -Dm755 "$srcdir"/e54c-usb-nvme-update.initd "$pkgdir"/etc/init.d/e54c-usb-nvme-update
  install -Dm644 "$srcdir"/e54c-usb-nvme-update.confd "$pkgdir"/etc/conf.d/e54c-usb-nvme-update
}

