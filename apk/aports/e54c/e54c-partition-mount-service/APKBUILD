pkgname=e54c-partition-mount-service
pkgver=0.1.0
pkgrel=2
pkgdesc="E54C OpenRC NVMe Partition mounter"
url="https://example.invalid/e54c-alpine"
arch="aarch64"
license="MIT"
depends="openrc busybox"
source="
  e54c-partition-mount.sh
  e54c-partition-mount.initd
  e54c-partition-mount.confd
"
builddir="$srcdir"
options="!check"

package() {
  install -Dm755 "$srcdir"/e54c-partition-mount.sh "$pkgdir"/usr/sbin/e54c-partition-mount

  install -Dm755 "$srcdir"/e54c-partition-mount.initd "$pkgdir"/etc/init.d/e54c-partition-mount
  install -Dm644 "$srcdir"/e54c-partition-mount.confd "$pkgdir"/etc/conf.d/e54c-partition-mount
}

