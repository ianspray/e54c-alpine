# Board-specific U-Boot asset fetch profile for E25.

UBOOT_FETCH_MODE="${UBOOT_FETCH_MODE:-compressed-disk-image}"
DISK_IMAGE_URL="${DISK_IMAGE_URL:-https://github.com/radxa-build/radxa-e25/releases/download/rsdk-b1/radxa-e25_bullseye_cli_b1.output.img.xz}"
DISK_IMAGE_FILENAME="${DISK_IMAGE_FILENAME:-radxa-e25_bullseye_cli_b1.output.img.xz}"
SPI_IDBLOADER_LBA="${SPI_IDBLOADER_LBA:-64}"
SPI_UBOOT_ITB_LBA="${SPI_UBOOT_ITB_LBA:-16384}"
IDBLOADER_SIZE_BYTES="${IDBLOADER_SIZE_BYTES:-319488}"
UBOOT_ITB_SIZE_BYTES="${UBOOT_ITB_SIZE_BYTES:-1484288}"
