BOARD_ROOTMODE_SERVICE_NAME="${BOARD_ROOTMODE_SERVICE_NAME:-e52c-root-mode}"

BOARD_UBOOT_FETCH_PROFILE="${BOARD_UBOOT_FETCH_PROFILE:-$REPO_ROOT/boards/e52c/u-boot-fetch.env}"
