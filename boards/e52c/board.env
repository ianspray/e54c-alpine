BOARD_CONFIG_FILE_DEFAULT="${BOARD_CONFIG_FILE_DEFAULT:-$REPO_ROOT/boards/e52c/config.txt}"
BOARD_SERIAL_TTY="${BOARD_SERIAL_TTY:-ttyFIQ0}"
BOARD_SERIAL_BAUD="${BOARD_SERIAL_BAUD:-1500000}"

BOARD_UBOOT_ASSETS_DIR="${BOARD_UBOOT_ASSETS_DIR:-$REPO_ROOT/boards/e52c/u-boot}"
BOARD_SPI_IDBLOADER_LBA_DEFAULT="${BOARD_SPI_IDBLOADER_LBA_DEFAULT:-64}"
