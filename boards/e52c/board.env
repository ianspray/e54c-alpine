BOARD_CUSTOM_APK_PACKAGES_FILE="${BOARD_CUSTOM_APK_PACKAGES_FILE:-$REPO_ROOT/boards/e52c/alpine/custom-packages.txt}"
BOARD_ROOT_PASSWORD_SALT="${BOARD_ROOT_PASSWORD_SALT:-e52c}"
BOARD_BOOT_SERVICES="${BOARD_BOOT_SERVICES:-e52c-dev-perms e52c-bootmode-oneshot partition-mount}"
