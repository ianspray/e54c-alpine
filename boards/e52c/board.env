BOARD_UPDATER_TARGET_DEVICE_DEFAULT="${BOARD_UPDATER_TARGET_DEVICE_DEFAULT:-/dev/mmcblk1}"
BOARD_UPDATER_SERVICE_NAME="${BOARD_UPDATER_SERVICE_NAME:-e52c-usb-emmc-update}"
