# SPDX-License-Identifier: MIT
# Board profile: Raspberry Pi 4

BOARD_DISPLAY_NAME="${BOARD_DISPLAY_NAME:-Raspberry Pi 4}"

# Pi firmware-native boot path (no SPI U-Boot injection).
BOARD_BOOT_SCHEME="${BOARD_BOOT_SCHEME:-rpi-firmware}"
BOARD_BOOTLOADER_MODE="${BOARD_BOOTLOADER_MODE:-none}"

BOARD_DTB_SUBDIR_DEFAULT="${BOARD_DTB_SUBDIR_DEFAULT:-broadcom}"
BOARD_DTB_NAME_DEFAULT="${BOARD_DTB_NAME_DEFAULT:-bcm2711-rpi-4-b.dtb}"
BOARD_USB_UPDATER_DTB_NAME_DEFAULT="${BOARD_USB_UPDATER_DTB_NAME_DEFAULT:-bcm2711-rpi-4-b.dtb}"
BOARD_CONFIG_FILE_DEFAULT="${BOARD_CONFIG_FILE_DEFAULT:-$REPO_ROOT/boards/rpi4/config.txt}"

BOARD_SERIAL_TTY="${BOARD_SERIAL_TTY:-ttyAMA0}"
BOARD_SERIAL_BAUD="${BOARD_SERIAL_BAUD:-115200}"
BOARD_KERNEL_CMDLINE_BASE_DEFAULT="${BOARD_KERNEL_CMDLINE_BASE_DEFAULT:-root=PARTLABEL=rootfs rootfstype=ext4 rootwait=30 console=ttyAMA0,115200}"

# Source kernel/firmware/modules from Alpine's official Raspberry Pi image.
BOARD_KERNEL_SOURCE_MODE="${BOARD_KERNEL_SOURCE_MODE:-alpine-rpi-image}"
BOARD_RPI_RELEASE_IMAGE_URL_DEFAULT="${BOARD_RPI_RELEASE_IMAGE_URL_DEFAULT:-https://dl-cdn.alpinelinux.org/alpine/v3.23/releases/aarch64/alpine-rpi-3.23.3-aarch64.img.gz}"
BOARD_RPI_RELEASE_IMAGE_FILENAME_DEFAULT="${BOARD_RPI_RELEASE_IMAGE_FILENAME_DEFAULT:-alpine-rpi-3.23.3-aarch64.img.gz}"

# Keep the standard path shape so Makefile targets remain uniform.
BOARD_UBOOT_ASSETS_DIR="${BOARD_UBOOT_ASSETS_DIR:-$REPO_ROOT/boards/rpi4/u-boot}"

BOARD_ALPINE_INTERFACES_FILE="${BOARD_ALPINE_INTERFACES_FILE:-$REPO_ROOT/boards/rpi4/alpine/interfaces}"
BOARD_ALPINE_MODULES_FILE="${BOARD_ALPINE_MODULES_FILE:-$REPO_ROOT/boards/rpi4/alpine/modules}"
BOARD_ALPINE_PACKAGE_LIST_FILE="${BOARD_ALPINE_PACKAGE_LIST_FILE:-$REPO_ROOT/boards/rpi4/alpine/packages.txt}"
BOARD_CUSTOM_APK_PACKAGES_FILE="${BOARD_CUSTOM_APK_PACKAGES_FILE:-$REPO_ROOT/boards/rpi4/alpine/custom-packages.txt}"

BOARD_ROOT_PASSWORD_SALT="${BOARD_ROOT_PASSWORD_SALT:-rpi4}"
BOARD_BOOT_SERVICES="${BOARD_BOOT_SERVICES:-rpi4-dev-perms rpi4-bootmode-oneshot rpi4-partition-mount}"
BOARD_IMMUTABLE_ROOT_SERVICE="${BOARD_IMMUTABLE_ROOT_SERVICE:-rpi4-root-mode}"
BOARD_NET_BANNER_SERVICE_NAME="${BOARD_NET_BANNER_SERVICE_NAME:-show-net-addrs}"
BOARD_BOOT_NTP_SERVICE_NAME="${BOARD_BOOT_NTP_SERVICE_NAME:-rpi4-ntp-sync}"

BOARD_UPDATER_SERVICE_NAME="${BOARD_UPDATER_SERVICE_NAME:-rpi4-usb-nvme-update}"
BOARD_UPDATER_RUNNER_BIN="${BOARD_UPDATER_RUNNER_BIN:-rpi4-run-usb-update}"
BOARD_ROOTMODE_SERVICE_NAME="${BOARD_ROOTMODE_SERVICE_NAME:-rpi4-root-mode}"
