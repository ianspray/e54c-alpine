# SPDX-License-Identifier: MIT
# Board profile: Radxa ROCK 5B

BOARD_DISPLAY_NAME="${BOARD_DISPLAY_NAME:-Radxa ROCK 5B}"
BOARD_BSP_PROFILE="${BOARD_BSP_PROFILE:-rk2410}"

# Vendor source defaults used by Radxa BSP rk2410 profile.
BOARD_KERNEL_REPO_DEFAULT="${BOARD_KERNEL_REPO_DEFAULT:-https://github.com/radxa/kernel.git}"
BOARD_KERNEL_BRANCH_DEFAULT="${BOARD_KERNEL_BRANCH_DEFAULT:-linux-6.1-stan-rkr5.1}"
BOARD_UBOOT_REPO_DEFAULT="${BOARD_UBOOT_REPO_DEFAULT:-https://github.com/radxa/u-boot.git}"
BOARD_UBOOT_BRANCH_DEFAULT="${BOARD_UBOOT_BRANCH_DEFAULT:-next-dev-v2024.10}"

BOARD_KERNEL_EXPECTED_DTS="${BOARD_KERNEL_EXPECTED_DTS:-arch/arm64/boot/dts/rockchip/rk3588-rock-5b.dts}"
BOARD_KERNEL_DTBS="${BOARD_KERNEL_DTBS:-rk3588-rock-5b.dtb rk3588-rock-5b-plus.dtb}"
BOARD_KERNEL_FRAGMENT_FILE="${BOARD_KERNEL_FRAGMENT_FILE:-$REPO_ROOT/boards/rock5b/kernel/custom-kernel.fragment}"

BOARD_DTB_NAME_DEFAULT="${BOARD_DTB_NAME_DEFAULT:-rk3588-rock-5b.dtb}"
BOARD_USB_UPDATER_DTB_NAME_DEFAULT="${BOARD_USB_UPDATER_DTB_NAME_DEFAULT:-rk3588-rock-5b.dtb}"
BOARD_CONFIG_FILE_DEFAULT="${BOARD_CONFIG_FILE_DEFAULT:-$REPO_ROOT/boards/rock5b/config.txt}"

BOARD_UBOOT_ASSETS_DIR="${BOARD_UBOOT_ASSETS_DIR:-$REPO_ROOT/boards/rock5b/u-boot}"
# Radxa ROCK 5B docs "SPI Image" entry:
# https://dl.radxa.com/rock5/sw/images/loader/rock-5b/release/rock-5b-spi-image-gd1cf491-20240523.img
BOARD_SPI_BASE_IMAGE_URL_DEFAULT="${BOARD_SPI_BASE_IMAGE_URL_DEFAULT:-https://dl.radxa.com/rock5/sw/images/loader/rock-5b/release/rock-5b-spi-image-gd1cf491-20240523.img}"
BOARD_SPI_BASE_IMAGE_FILENAME_DEFAULT="${BOARD_SPI_BASE_IMAGE_FILENAME_DEFAULT:-rock-5b-spi-image-gd1cf491-20240523.img}"
BOARD_SPI_IMAGE_SIZE_BYTES_DEFAULT="${BOARD_SPI_IMAGE_SIZE_BYTES_DEFAULT:-16777216}"
BOARD_SPI_IDBLOADER_LBA_DEFAULT="${BOARD_SPI_IDBLOADER_LBA_DEFAULT:-64}"
BOARD_SPI_UBOOT_ITB_LBA_DEFAULT="${BOARD_SPI_UBOOT_ITB_LBA_DEFAULT:-16384}"
BOARD_IDBLOADER_SIZE_BYTES_DEFAULT="${BOARD_IDBLOADER_SIZE_BYTES_DEFAULT:-319488}"
BOARD_UBOOT_ITB_SIZE_BYTES_DEFAULT="${BOARD_UBOOT_ITB_SIZE_BYTES_DEFAULT:-1484288}"
BOARD_SPL_LOADER_URL_DEFAULT="${BOARD_SPL_LOADER_URL_DEFAULT:-https://dl.radxa.com/rock5/sw/images/loader/rock-5b/release/rk3588_spl_loader_v1.15.113.bin}"

BOARD_ALPINE_INTERFACES_FILE="${BOARD_ALPINE_INTERFACES_FILE:-$REPO_ROOT/boards/rock5b/alpine/interfaces}"
BOARD_ALPINE_MODULES_FILE="${BOARD_ALPINE_MODULES_FILE:-$REPO_ROOT/boards/rock5b/alpine/modules}"
BOARD_ROOT_PASSWORD_SALT="${BOARD_ROOT_PASSWORD_SALT:-rock5b}"
BOARD_BOOT_SERVICES="${BOARD_BOOT_SERVICES:-e54c-dev-perms e54c-bootmode-oneshot e54c-partition-mount}"
BOARD_IMMUTABLE_ROOT_SERVICE="${BOARD_IMMUTABLE_ROOT_SERVICE:-e54c-root-mode}"
BOARD_NET_BANNER_SERVICE_NAME="${BOARD_NET_BANNER_SERVICE_NAME:-show-net-addrs}"
BOARD_BOOT_NTP_SERVICE_NAME="${BOARD_BOOT_NTP_SERVICE_NAME:-e54c-ntp-sync}"

# These remain pointed at existing updater services until board-specific
# package naming is introduced.
BOARD_UPDATER_SERVICE_NAME="${BOARD_UPDATER_SERVICE_NAME:-e54c-usb-nvme-update}"
BOARD_UPDATER_RUNNER_BIN="${BOARD_UPDATER_RUNNER_BIN:-e54c-run-usb-update}"
BOARD_ROOTMODE_SERVICE_NAME="${BOARD_ROOTMODE_SERVICE_NAME:-e54c-root-mode}"
