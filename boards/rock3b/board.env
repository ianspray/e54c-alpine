# SPDX-License-Identifier: MIT
# Board profile: Radxa ROCK 3B

BOARD_DISPLAY_NAME="${BOARD_DISPLAY_NAME:-Radxa ROCK 3B}"
BOARD_BSP_PROFILE="${BOARD_BSP_PROFILE:-rk356x}"

# Vendor source defaults used by Radxa kernel/U-Boot trees.
BOARD_KERNEL_REPO_DEFAULT="${BOARD_KERNEL_REPO_DEFAULT:-https://github.com/radxa/kernel.git}"
BOARD_KERNEL_BRANCH_DEFAULT="${BOARD_KERNEL_BRANCH_DEFAULT:-linux-6.1-stan-rkr5.1}"
BOARD_UBOOT_REPO_DEFAULT="${BOARD_UBOOT_REPO_DEFAULT:-https://github.com/radxa/u-boot.git}"
BOARD_UBOOT_BRANCH_DEFAULT="${BOARD_UBOOT_BRANCH_DEFAULT:-next-dev-v2024.10}"

# ROCK 3B needs a backported board DTS on the shared Radxa BSP kernel branch.
BOARD_KERNEL_EXPECTED_DTS="${BOARD_KERNEL_EXPECTED_DTS:-arch/arm64/boot/dts/rockchip/rk3568-rock-3b.dts}"
BOARD_KERNEL_DTBS="${BOARD_KERNEL_DTBS:-rk3568-rock-3b.dtb}"
BOARD_KERNEL_FRAGMENT_FILE="${BOARD_KERNEL_FRAGMENT_FILE:-$REPO_ROOT/boards/rock3b/kernel/custom-kernel.fragment}"
BOARD_KERNEL_PATCH_DIR="${BOARD_KERNEL_PATCH_DIR:-$REPO_ROOT/boards/rock3b/kernel/patches}"

BOARD_DTB_NAME_DEFAULT="${BOARD_DTB_NAME_DEFAULT:-rk3568-rock-3b.dtb}"
BOARD_USB_UPDATER_DTB_NAME_DEFAULT="${BOARD_USB_UPDATER_DTB_NAME_DEFAULT:-rk3568-rock-3b.dtb}"
BOARD_CONFIG_FILE_DEFAULT="${BOARD_CONFIG_FILE_DEFAULT:-$REPO_ROOT/boards/rock3b/config.txt}"
BOARD_SERIAL_TTY="${BOARD_SERIAL_TTY:-ttyS2}"
BOARD_SERIAL_BAUD="${BOARD_SERIAL_BAUD:-1500000}"

BOARD_UBOOT_ASSETS_DIR="${BOARD_UBOOT_ASSETS_DIR:-$REPO_ROOT/boards/rock3b/u-boot}"
# Radxa ROCK 3B loader directory:
# https://dl.radxa.com/rock3/images/loader/rock-3b/
BOARD_SPI_BASE_IMAGE_URL_DEFAULT="${BOARD_SPI_BASE_IMAGE_URL_DEFAULT:-https://dl.radxa.com/rock3/images/loader/rock-3b/rock-3b-spi.img}"
BOARD_SPI_BASE_IMAGE_FILENAME_DEFAULT="${BOARD_SPI_BASE_IMAGE_FILENAME_DEFAULT:-rock-3b-spi.img}"
BOARD_SPI_IMAGE_SIZE_BYTES_DEFAULT="${BOARD_SPI_IMAGE_SIZE_BYTES_DEFAULT:-16777216}"
BOARD_SPI_IDBLOADER_LBA_DEFAULT="${BOARD_SPI_IDBLOADER_LBA_DEFAULT:-64}"
BOARD_SPI_UBOOT_ITB_LBA_DEFAULT="${BOARD_SPI_UBOOT_ITB_LBA_DEFAULT:-16384}"
BOARD_IDBLOADER_SIZE_BYTES_DEFAULT="${BOARD_IDBLOADER_SIZE_BYTES_DEFAULT:-319488}"
BOARD_UBOOT_ITB_SIZE_BYTES_DEFAULT="${BOARD_UBOOT_ITB_SIZE_BYTES_DEFAULT:-1484288}"
BOARD_SPL_LOADER_URL_DEFAULT="${BOARD_SPL_LOADER_URL_DEFAULT:-https://dl.radxa.com/rock3/images/loader/rock-3b/rk356x_spl_loader_ddr1056_v1.10.111.bin}"

BOARD_ALPINE_INTERFACES_FILE="${BOARD_ALPINE_INTERFACES_FILE:-$REPO_ROOT/boards/rock3b/alpine/interfaces}"
BOARD_ALPINE_MODULES_FILE="${BOARD_ALPINE_MODULES_FILE:-$REPO_ROOT/boards/rock3b/alpine/modules}"
BOARD_ALPINE_PACKAGE_LIST_FILE="${BOARD_ALPINE_PACKAGE_LIST_FILE:-$REPO_ROOT/boards/rock3b/alpine/packages.txt}"
BOARD_CUSTOM_APK_PACKAGES_FILE="${BOARD_CUSTOM_APK_PACKAGES_FILE:-$REPO_ROOT/boards/rock3b/alpine/custom-packages.txt}"
BOARD_ROOT_PASSWORD_SALT="${BOARD_ROOT_PASSWORD_SALT:-rock3b}"
BOARD_BOOT_SERVICES="${BOARD_BOOT_SERVICES:-rock3b-dev-perms rock3b-bootmode-oneshot partition-mount}"
BOARD_IMMUTABLE_ROOT_SERVICE="${BOARD_IMMUTABLE_ROOT_SERVICE:-rock3b-root-mode}"
BOARD_NET_BANNER_SERVICE_NAME="${BOARD_NET_BANNER_SERVICE_NAME:-show-net-addrs}"
BOARD_BOOT_NTP_SERVICE_NAME="${BOARD_BOOT_NTP_SERVICE_NAME:-rock3b-ntp-sync}"

BOARD_UPDATER_SERVICE_NAME="${BOARD_UPDATER_SERVICE_NAME:-rock3b-usb-nvme-update}"
BOARD_UPDATER_RUNNER_BIN="${BOARD_UPDATER_RUNNER_BIN:-rock3b-run-usb-update}"
BOARD_ROOTMODE_SERVICE_NAME="${BOARD_ROOTMODE_SERVICE_NAME:-rock3b-root-mode}"

BOARD_UBOOT_FETCH_PROFILE="${BOARD_UBOOT_FETCH_PROFILE:-$REPO_ROOT/boards/rock3b/u-boot-fetch.env}"
