# SPDX-License-Identifier: MIT
# Board profile: FriendlyElec NanoPi R3S

BOARD_DISPLAY_NAME="${BOARD_DISPLAY_NAME:-FriendlyElec NanoPi R3S}"
BOARD_BSP_PROFILE="${BOARD_BSP_PROFILE:-rk356x}"

# Build from FriendlyElec's kernel tree by default so the board fragment and
# DTB preparation logic actually apply to the running kernel. Keep the
# published Alpine image assets below as a reference/fallback source.
BOARD_KERNEL_SOURCE_MODE="${BOARD_KERNEL_SOURCE_MODE:-radxa-git}"
BOARD_KERNEL_DTBS="${BOARD_KERNEL_DTBS:-rk3566-nanopi-r3-rev02.dtb}"

# FriendlyElec Alpine 2026-03-04 image-assets-rk3566.tgz members:
# kernel.img  = 8-byte KRNL header + raw ARM64 Image (kernel 6.1.x)
# resource.img = Rockchip RSCE format containing all board DTBs
# rootfs.tgz  = Alpine rootfs with kernel modules
BOARD_FRIENDLYELEC_IMAGE_ARCHIVE_URL="${BOARD_FRIENDLYELEC_IMAGE_ARCHIVE_URL:-https://github.com/friendlyarm/Actions-Alpine-Linux/releases/download/Alpine-2026-03-04/image-assets-rk3566.tgz}"
BOARD_FRIENDLYELEC_IMAGE_ARCHIVE_FILENAME="${BOARD_FRIENDLYELEC_IMAGE_ARCHIVE_FILENAME:-image-assets-rk3566.tgz}"
BOARD_FRIENDLYELEC_IMAGE_KERNEL_MEMBER="${BOARD_FRIENDLYELEC_IMAGE_KERNEL_MEMBER:-image-assets-rk3566/alpine-linux-arm64/kernel.img}"
BOARD_FRIENDLYELEC_IMAGE_RESOURCE_MEMBER="${BOARD_FRIENDLYELEC_IMAGE_RESOURCE_MEMBER:-image-assets-rk3566/alpine-linux-arm64/resource.img}"
BOARD_FRIENDLYELEC_IMAGE_ROOTFS_MEMBER="${BOARD_FRIENDLYELEC_IMAGE_ROOTFS_MEMBER:-image-assets-rk3566/rootfs.tgz}"

# Keep source references for fallback to radxa-git mode if needed.
BOARD_KERNEL_REPO_DEFAULT="${BOARD_KERNEL_REPO_DEFAULT:-https://github.com/friendlyarm/kernel-rockchip.git}"
BOARD_KERNEL_BRANCH_DEFAULT="${BOARD_KERNEL_BRANCH_DEFAULT:-nanopi6-v6.1.y}"
BOARD_KERNEL_DEFCONFIG_TARGET_DEFAULT="${BOARD_KERNEL_DEFCONFIG_TARGET_DEFAULT:-nanopi5_linux_defconfig}"
BOARD_KERNEL_DEFCONFIG_EXTRA_TARGETS_DEFAULT="${BOARD_KERNEL_DEFCONFIG_EXTRA_TARGETS_DEFAULT:-kvm.config}"
BOARD_KERNEL_CONFIG_MODE="${BOARD_KERNEL_CONFIG_MODE:-defconfig-targets}"
BOARD_KERNEL_EXPECTED_DTS="${BOARD_KERNEL_EXPECTED_DTS:-arch/arm64/boot/dts/rockchip/rk3566-nanopi-r3-rev02.dts}"
BOARD_KERNEL_FRAGMENT_FILE="${BOARD_KERNEL_FRAGMENT_FILE:-$REPO_ROOT/boards/r3s/kernel/custom-kernel.fragment}"
BOARD_KERNEL_PATCH_DIR="${BOARD_KERNEL_PATCH_DIR:-}"
BOARD_KERNEL_PREPARE_SCRIPT="${BOARD_KERNEL_PREPARE_SCRIPT:-$REPO_ROOT/boards/r3s/kernel/prepare-kernel.sh}"

BOARD_DTB_NAME_DEFAULT="${BOARD_DTB_NAME_DEFAULT:-rk3566-nanopi-r3-rev02.dtb}"
BOARD_USB_UPDATER_DTB_NAME_DEFAULT="${BOARD_USB_UPDATER_DTB_NAME_DEFAULT:-rk3566-nanopi-r3-rev02.dtb}"
BOARD_CONFIG_FILE_DEFAULT="${BOARD_CONFIG_FILE_DEFAULT:-$REPO_ROOT/boards/r3s/config.txt}"
BOARD_BOOTABLE_GPT_PARTITIONS_DEFAULT="${BOARD_BOOTABLE_GPT_PARTITIONS_DEFAULT:-2 3}"
BOARD_SERIAL_TTY="${BOARD_SERIAL_TTY:-ttyFIQ0}"
BOARD_SERIAL_BAUD="${BOARD_SERIAL_BAUD:-1500000}"
# The FriendlyElec vendor kernel accepts bare rootwait on direct-root boots;
# rootwait=30 is handled only by our initramfs path, not by the kernel itself.
# Its runtime serial console path is ttyFIQ0, while earlycon still uses uart2.
BOARD_KERNEL_CMDLINE_BASE_DEFAULT="${BOARD_KERNEL_CMDLINE_BASE_DEFAULT:-root=PARTLABEL=rootfs rootfstype=ext4 rootwait console=ttyFIQ0,1500000n8 earlycon=uart8250,mmio32,0xfe660000 keep_bootcon ignore_loglevel loglevel=8}"
BOARD_ENABLE_INITRAMFS_BOOT_DEFAULT="${BOARD_ENABLE_INITRAMFS_BOOT_DEFAULT:-1}"
# No BOARD_KERNEL_CMDLINE_IMMUTABLE_DEFAULT override: use the assemble-image.sh default (diskless tmpfs mode).

BOARD_UBOOT_ASSETS_DIR="${BOARD_UBOOT_ASSETS_DIR:-$REPO_ROOT/boards/r3s/u-boot}"
BOARD_BOOTLOADER_MODE="${BOARD_BOOTLOADER_MODE:-spi-dd}"
BOARD_SPI_IDBLOADER_LBA_DEFAULT="${BOARD_SPI_IDBLOADER_LBA_DEFAULT:-64}"
BOARD_SPI_UBOOT_ITB_LBA_DEFAULT="${BOARD_SPI_UBOOT_ITB_LBA_DEFAULT:-16384}"
BOARD_IDBLOADER_SIZE_BYTES_DEFAULT="${BOARD_IDBLOADER_SIZE_BYTES_DEFAULT:-319488}"
BOARD_UBOOT_ITB_SIZE_BYTES_DEFAULT="${BOARD_UBOOT_ITB_SIZE_BYTES_DEFAULT:-4194304}"

BOARD_ALPINE_INTERFACES_FILE="${BOARD_ALPINE_INTERFACES_FILE:-$REPO_ROOT/boards/r3s/alpine/interfaces}"
BOARD_ALPINE_MODULES_FILE="${BOARD_ALPINE_MODULES_FILE:-$REPO_ROOT/boards/r3s/alpine/modules}"
BOARD_ALPINE_PACKAGE_LIST_FILE="${BOARD_ALPINE_PACKAGE_LIST_FILE:-$REPO_ROOT/boards/r3s/alpine/packages.txt}"
BOARD_CUSTOM_APK_PACKAGES_FILE="${BOARD_CUSTOM_APK_PACKAGES_FILE:-$REPO_ROOT/boards/r3s/alpine/custom-packages.txt}"
BOARD_ROOT_PASSWORD_SALT="${BOARD_ROOT_PASSWORD_SALT:-r3s}"
BOARD_BOOT_SERVICES="${BOARD_BOOT_SERVICES:-partition-mount}"
BOARD_IMMUTABLE_ROOT_SERVICE="${BOARD_IMMUTABLE_ROOT_SERVICE:-}"
BOARD_NET_BANNER_SERVICE_NAME="${BOARD_NET_BANNER_SERVICE_NAME:-show-net-addrs}"
BOARD_BOOT_NTP_SERVICE_NAME="${BOARD_BOOT_NTP_SERVICE_NAME:-r3s-ntp-sync}"

BOARD_UPDATER_TARGET_DEVICE_DEFAULT="${BOARD_UPDATER_TARGET_DEVICE_DEFAULT:-/dev/mmcblk2}"
BOARD_UPDATER_DISKLESS_DEFAULT="${BOARD_UPDATER_DISKLESS_DEFAULT:-0}"
BOARD_UPDATER_SERVICE_NAME="${BOARD_UPDATER_SERVICE_NAME:-r3s-usb-emmc-update}"
BOARD_UPDATER_RUNNER_BIN="${BOARD_UPDATER_RUNNER_BIN:-r3s-run-usb-update}"
BOARD_ROOTMODE_SERVICE_NAME="${BOARD_ROOTMODE_SERVICE_NAME:-r3s-root-mode}"

BOARD_UBOOT_FETCH_PROFILE="${BOARD_UBOOT_FETCH_PROFILE:-$REPO_ROOT/boards/r3s/u-boot-fetch.env}"
BOARD_FRIENDLYELEC_IMAGE_DTB_PATCH_SCRIPT="${BOARD_FRIENDLYELEC_IMAGE_DTB_PATCH_SCRIPT:-$REPO_ROOT/boards/r3s/kernel/patch-dtb.sh}"
